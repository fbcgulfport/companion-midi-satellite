{
  "name": "companion-midi-satellite",
  "version": "3.0.0-0",
  "description": "MIDI Note-On to Companion button pusher menubar app",
  "author": {
    "name": "Julian Waller",
    "email": "git@julusian.co.uk",
    "url": "https://github.com/julusian"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fbcgulfport/companion-midi-satellite.git"
  },
  "bugs": {
    "url": "https://github.com/fbcgulfport/companion-midi-satellite/issues"
  },
  "homepage": "https://github.com/fbcgulfport/companion-midi-satellite#readme",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "satellite",
    "webui"
  ],
  "scripts": {
    "postinstall": "husky",
    "dev": "yarn workspace companion-midi-satellite-app dev",
    "dev:electron": "yarn workspace companion-midi-satellite-app dev:electron",
    "dev:webui": "yarn workspace webui dev",
    "build": "yarn workspaces foreach --all run build",
    "lint:raw": "eslint",
    "lint": "eslint .",
    "license-validate": "sofie-licensecheck",
    "dist": "run build && tsx tools/build_electron.mts",
    "watch-types": "tsc --build --watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sofie-automation/eslint-plugin": "^0.2.1",
    "@tsconfig/node24": "^24.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "zx": "^8.8.5"
  },
  "resolutions": {
    "node-gyp": "^12.2.0"
  },
  "engines": {
    "node": "^24.13"
  },
  "packageManager": "yarn@4.13.0"
}
